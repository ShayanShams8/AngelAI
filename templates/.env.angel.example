# Angel AI Configuration
# Copy this file to .env.angel and fill in your values.

# Kaggle (for general analysis with public datasets)
KAGGLE_USERNAME=
KAGGLE_KEY=

# Google Cloud (for BigQuery, Vertex AI, Google Cloud services)
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_CLOUD_PROJECT=

# Shopify (if using Shopify platform)
SHOPIFY_SHOP_DOMAIN=
SHOPIFY_ACCESS_TOKEN=

# Square (if using Square platform)
SQUARE_ACCESS_TOKEN=
SQUARE_ENVIRONMENT=

# QuickBooks (if using QuickBooks platform)
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
QUICKBOOKS_REFRESH_TOKEN=
QUICKBOOKS_REALM_ID=
